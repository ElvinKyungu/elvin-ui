# Chariow API key — required in production to validate license keys
# Get it from your Chariow dashboard → Settings → API
CHARIOW_API_KEY=your_chariow_api_key_here

# Session encryption secret — REQUIRED in production, must be 32+ characters
# Generate with: openssl rand -base64 32
# Never commit the real value to version control
SESSION_SECRET=change-me-to-a-random-32-plus-char-string

# Public site URL (used for OG images and canonical URLs)
NUXT_PUBLIC_SITE_URL=https://elvin-ui.com
